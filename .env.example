# ============================================================
# FMS (FileService) 配置文件
# ============================================================
# 复制此文件为 .env 并根据实际情况修改配置
# cp .env.example .env
#
# 全新安装时，系统会自动生成密钥并写入 .env
# 如果已有数据（数据库文件存在），系统会拒绝自动生成密钥，
# 此时必须手动配置正确的密钥值，否则已有加密文件将无法解密！
# ============================================================

# ---- 服务器端口 ----
PORT=88

# ---- 数据库路径 ----
DB_PATH=./data/fileservice.db

# ---- Redis 配置 ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=15
REDIS_PREFIX=ambush:

# ---- SSL/HTTPS（可选）----
# SSL_ENABLED=false
# SSL_KEY_PATH=./cer/your-domain.key
# SSL_CERT_PATH=./cer/your-domain.pem
# SSL_PORT=8843

# ---- 邮件服务（QQ邮箱 SMTP，可选）----
# 不设置则邮件功能不可用（注册验证码/密码重置/回收站提醒/存储告警）
# EMAIL_USER=your-email@foxmail.com
# EMAIL_AUTH_CODE=你的QQ邮箱SMTP授权码（在QQ邮箱设置→账户→POP3/SMTP服务中获取）
# EMAIL_FROM=文件管理系统

# ---- 安全密钥（全新安装时自动生成，请妥善保管）----
# ⚠️ SYSTEM_MASTER_KEY 用于加密所有上传文件！
# 丢失此密钥将导致所有已上传文件永久无法解密！
# SESSION_SECRET=
# SYSTEM_MASTER_KEY=

# ---- 预览Token密钥（可选，默认使用 SYSTEM_MASTER_KEY）----
# PREVIEW_TOKEN_SECRET=

# ---- CORS 白名单（逗号分隔）----
# 留空 = 开发模式，允许所有来源（不安全！）
# 示例: CORS_ORIGINS=example.com,app.example.com
# CORS_ORIGINS=

# ---- App 配置 ----
# App 基础 URL（用于生成分享链接、邮件中的链接等）
APP_BASE_URL=http://127.0.0.1:88

# ---- 存储健康告警邮件接收人 ----
# "admins" = 发送给所有管理员
# 具体邮箱（逗号分隔）= 发送给指定邮箱
# STORAGE_ALERT_EMAIL=admins

# ---- 日志级别 ----
# debug = 显示所有日志（开发调试用）
# info  = 显示常规日志（生产推荐）
# warn  = 仅显示警告和错误
# error = 仅显示错误
LOG_LEVEL=info
